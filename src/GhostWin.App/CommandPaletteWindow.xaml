<Window x:Class="GhostWin.App.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        SizeToContent="Height" Width="500"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="OnPreviewKeyDown"
        AutomationProperties.AutomationId="E2E_CommandPalette">

    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
            BorderBrush="{DynamicResource Divider.Brush}" BorderThickness="1"
            Margin="0,80,0,0" VerticalAlignment="Top"
            MaxHeight="400">
        <StackPanel>
            <TextBox x:Name="SearchBox" FontSize="14"
                     Background="{DynamicResource ApplicationBackgroundBrush}"
                     Foreground="{DynamicResource Text.Primary.Brush}"
                     BorderThickness="0" Padding="12,10"
                     FontFamily="Segoe UI Variable"
                     CaretBrush="{DynamicResource Text.Primary.Brush}"
                     TextChanged="OnSearchTextChanged"
                     AutomationProperties.AutomationId="E2E_PaletteSearch">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8,8,0,0"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <ListBox x:Name="ResultList"
                     Background="Transparent" BorderThickness="0"
                     MaxHeight="300"
                     Focusable="False" IsTabStop="False"
                     MouseDoubleClick="OnResultDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Palette.Item.Selected.Brush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItem.Hover.Brush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="12,8">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding KeyCombo}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Text.Tertiary.Brush}"
                                       FontFamily="Segoe UI Variable"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="13"
                                       Foreground="{DynamicResource Text.Primary.Brush}"
                                       FontFamily="Segoe UI Variable"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Border>
</Window>
