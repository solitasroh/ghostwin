<UserControl x:Class="GhostWin.App.Controls.NotificationPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:GhostWin.Core.Models;assembly=GhostWin.Core"
             xmlns:conv="clr-namespace:GhostWin.App.Converters"
             Background="#1C1C1E"
             AutomationProperties.AutomationId="E2E_NotificationPanel">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <SolidColorBrush x:Key="PanelBorder" Color="#2C2C2E"/>
        <SolidColorBrush x:Key="UnreadDot" Color="#007AFF"/>
        <SolidColorBrush x:Key="ReadCheck" Color="#636366"/>
        <SolidColorBrush x:Key="HeaderText" Color="#8E8E93"/>
        <SolidColorBrush x:Key="BodyText" Color="#8E8E93"/>
        <SolidColorBrush x:Key="TitleText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TimeText" Color="#636366"/>
        <SolidColorBrush x:Key="UnreadCountColor" Color="#FFB020"/>
        <SolidColorBrush x:Key="LinkColor" Color="#0091FF"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="12,10"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="NOTIFICATIONS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource HeaderText}" VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable"/>
                <Button DockPanel.Dock="Right" Content="Mark All Read"
                        FontSize="10" Foreground="{StaticResource LinkColor}"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Right" Cursor="Hand"
                        Command="{Binding MarkAllReadCommand}"
                        AutomationProperties.AutomationId="E2E_MarkAllRead"/>
            </DockPanel>
        </Border>

        <!-- Unread count -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
            <TextBlock FontSize="11" Foreground="{StaticResource UnreadCountColor}"
                       FontFamily="Segoe UI Variable">
                <Run Text="{Binding UnreadCount, Mode=OneWay}"/>
                <Run Text=" unread"/>
            </TextBlock>
        </Border>

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top" Text="No notifications"
                   FontSize="12" Foreground="{StaticResource HeaderText}"
                   FontFamily="Segoe UI Variable"
                   HorizontalAlignment="Center" Margin="0,24,0,0"
                   Visibility="{Binding HasNotifications,
                       Converter={StaticResource InverseBoolToVis}}"/>

        <!-- Notification list -->
        <ListBox ItemsSource="{Binding Notifications}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Focusable="False" IsTabStop="False"
                 AutomationProperties.AutomationId="E2E_NotificationList">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:NotificationEntry}">
                    <Border Padding="12,8" Cursor="Hand"
                            BorderBrush="{StaticResource PanelBorder}"
                            BorderThickness="0,0,0,1">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.NotificationClickCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Unread indicator -->
                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                     Fill="{StaticResource UnreadDot}"
                                     VerticalAlignment="Top" Margin="0,6,0,0"
                                     Visibility="{Binding IsRead,
                                         Converter={StaticResource InverseBoolToVis}}"/>
                            <TextBlock Grid.Column="0" Text="✓" FontSize="9"
                                       Foreground="{StaticResource ReadCheck}"
                                       VerticalAlignment="Top" Margin="0,2,0,0"
                                       Visibility="{Binding IsRead,
                                           Converter={StaticResource BoolToVis}}"/>

                            <StackPanel Grid.Column="1">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding ReceivedAt,
                                                   StringFormat=HH:mm}"
                                               FontSize="10"
                                               Foreground="{StaticResource TimeText}"
                                               FontFamily="Segoe UI Variable"/>
                                    <TextBlock Text="{Binding SessionTitle}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TitleText}"
                                               FontFamily="Segoe UI Variable"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                                <TextBlock Text="{Binding Body}"
                                           FontSize="11"
                                           Foreground="{StaticResource BodyText}"
                                           FontFamily="Segoe UI Variable"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
