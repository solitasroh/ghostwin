<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        M-16-A Design System — Dark theme tokens
        See docs/02-design/features/m16-a-design-system.design.md Section 3
        Naming: <Group>.<Variant>.<Modifier> (dot separator)
    -->

    <!-- Window group -->
    <!--
        M-16-B P0v5 (2026-04-29): Mica visibility re-balanced.

        P0v2 set alpha 0.7 (#B3) which was too conservative — in dark mode
        the Win11 OS Mica accent is itself a dark gray, so a 70% #0A0A0A
        chrome over a 30% dark-Mica blend is visually indistinguishable
        from the original opaque #0A0A0A. The user PC verification showed
        DWM accepting the Mica request (HRESULT=0) yet no perceived change.

        Edge / Microsoft Settings / cmux all use alpha ~0.4-0.5 for
        sidebar/titlebar so the OS color shows through clearly while
        text-on-chrome contrast stays above WCAG 4.5:1 against the
        composited tone. We pick alpha 0.4 (#66 prefix) — 60% Mica /
        40% chrome — which is the same blend Microsoft uses in the
        Settings app NavigationView.
    -->
    <SolidColorBrush x:Key="Window.Background.Brush" Color="#0A0A0A"/>
    <!--
        P0v6 (2026-04-29): TitleBar = fully transparent (#00000000) for
        decisive Mica visibility test. If user still sees no change at
        alpha 0, the failure is not in the alpha value but in a deeper
        layer (DirectComposition surface, DX11 child HWND airspace, or
        Win11 desktop wallpaper-tone Mica producing near-identical color
        to a black chrome). After confirmation, this will be relaxed to
        a usable alpha (0.3-0.5) for production text contrast.
    -->
    <SolidColorBrush x:Key="Window.TitleBar.Background.Brush" Color="#00000000"/>

    <!--
        Sidebar group. Opacity values track the existing inline usage
        in MainWindow.xaml (SidebarItemStyle hover/selected triggers,
        line 108 / 115 of pre-refactor file): hover 0.06, selected 0.10.
        M-16-B P0v5 (cmux pattern): Background alpha 0.4 (#66 prefix) so
        the OS Mica layer is clearly visible. Hover/Selected stay at
        0.06/0.10 white-overlay because they are *additive* tints over
        the base.
    -->
    <!--
        P0v6 (2026-04-29): Sidebar = fully transparent (#00000000). See
        Window.TitleBar.Background.Brush comment above for the rationale.
    -->
    <SolidColorBrush x:Key="Sidebar.Background.Brush" Color="#00000000"/>
    <SolidColorBrush x:Key="Sidebar.Hover.Brush" Color="#FFFFFF" Opacity="0.06"/>
    <SolidColorBrush x:Key="Sidebar.Selected.Brush" Color="#FFFFFF" Opacity="0.10"/>

    <!-- Text group (3-tier hierarchy) -->
    <SolidColorBrush x:Key="Text.Primary.Brush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Text.Secondary.Brush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="Text.Tertiary.Brush" Color="#636366"/>

    <!--
        Accent group. Accent.CloseHover.Brush uses the Windows system
        close-hover red (#E81123) rather than the audit's estimated
        #5A1F1F — see CloseButtonStyle in MainWindow.xaml line 81.
    -->
    <SolidColorBrush x:Key="Accent.Primary.Brush" Color="#0091FF"/>
    <SolidColorBrush x:Key="Accent.CloseHover.Brush" Color="#E81123"/>

    <!--
        Terminal group (C9 fix — Color resource exposed for engine RGB extraction)
        FR-09: App.xaml.cs SettingsChangedMessage handler reads Terminal.Background.Color
        and calls IEngineService.RenderSetClearColor(uint rgb).
    -->
    <Color x:Key="Terminal.Background.Color">#1E1E2E</Color>
    <SolidColorBrush x:Key="Terminal.Background.Brush" Color="#1E1E2E"/>

    <!-- Divider -->
    <SolidColorBrush x:Key="Divider.Brush" Color="#3A3A3C"/>

    <!-- Button -->
    <SolidColorBrush x:Key="Button.Hover.Brush" Color="#3E3E42"/>

    <!-- Generic list item state (shared by Notification list and CommandPalette result list) -->
    <SolidColorBrush x:Key="ListItem.Hover.Brush" Color="#2A2A2C"/>

    <!-- CommandPalette-specific state -->
    <SolidColorBrush x:Key="Palette.Item.Selected.Brush" Color="#3A3A3C"/>

    <!-- Notification panel group (C2 — replaces NotificationPanelControl self-resources) -->
    <SolidColorBrush x:Key="Notification.Background.Brush" Color="#1C1C1E"/>
    <SolidColorBrush x:Key="Notification.PanelBorder.Brush" Color="#2C2C2E"/>
    <SolidColorBrush x:Key="Notification.UnreadDot.Brush" Color="#007AFF"/>
    <SolidColorBrush x:Key="Notification.UnreadCount.Brush" Color="#FFB020"/>
    <SolidColorBrush x:Key="Notification.Link.Brush" Color="#0091FF"/>

    <!--
        Workspace agent state group (C5 — replaces WorkspaceItemViewModel.cs Apple/cmux constants)
        AgentState enum: Running / WaitingForInput / Error / Completed (Idle is Brushes.Transparent)
    -->
    <SolidColorBrush x:Key="Workspace.Agent.Running.Brush" Color="#34C759"/>
    <SolidColorBrush x:Key="Workspace.Agent.Waiting.Brush" Color="#007AFF"/>
    <SolidColorBrush x:Key="Workspace.Agent.Error.Brush" Color="#FF3B30"/>
    <SolidColorBrush x:Key="Workspace.Agent.Completed.Brush" Color="#8E8E93"/>

    <!--
        wpfui-compatible keys (existing names preserved — wpfui controls bind to these directly)
        Used by SettingsPageControl etc.
    -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2C2C2E"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8E8E93"/>

</ResourceDictionary>
