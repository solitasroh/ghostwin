<Application x:Class="GhostWin.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <!-- M-16-A FR-04: GhostWin design system tokens.
                     Colors.Dark.xaml is the boot default; runtime swap to
                     Colors.Light.xaml is wired in App.xaml.cs OnStartup
                     and (later) MainWindowViewModel.ApplyThemeColors. -->
                <ResourceDictionary Source="/GhostWin.App;component/Themes/Colors.Dark.xaml" />
                <ResourceDictionary Source="/GhostWin.App;component/Themes/Spacing.xaml" />
                <ResourceDictionary Source="/GhostWin.App;component/Themes/FocusVisuals.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
