<Window x:Class="GhostWin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:GhostWin.App.ViewModels"
        xmlns:controls="clr-namespace:GhostWin.App.Controls"
        xmlns:conv="clr-namespace:GhostWin.App.Converters"
        Title="{Binding WindowTitle}"
        Background="#1E1E2E"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:ActiveIndicatorBrushConverter x:Key="ActiveIndicatorBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}"/>
        <KeyBinding Gesture="Ctrl+W"
                    Command="{Binding CloseTabCommand}"
                    CommandParameter="{Binding SelectedTab}"/>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App title -->
            <TextBlock Grid.Column="0" Text="{Binding WindowTitle}"
                       VerticalAlignment="Center" Margin="12,0"
                       FontSize="12" Foreground="#CCCCCC"/>

            <!-- Caption buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Click="OnMinimize" Style="{StaticResource CaptionButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M 0,5 H 10" Stroke="#999" StrokeThickness="1"/>
                </Button>
                <Button Click="OnMaxRestore" Style="{StaticResource CaptionButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path x:Name="MaxRestoreIcon"
                          Data="M 0,0 H 10 V 10 H 0 Z" Stroke="#999" StrokeThickness="1"/>
                </Button>
                <Button Click="OnClose" Style="{StaticResource CloseButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="#999" StrokeThickness="1"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth}" MinWidth="120" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#2D2D30">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="12,8,12,8">
                        <TextBlock Text="GhostWin" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#CCCCCC"/>
                        <Button Content="＋ New Tab" Margin="0,8,0,0"
                                Command="{Binding NewTabCommand}"
                                HorizontalAlignment="Stretch"
                                Background="#3E3E42" Foreground="#CCCCCC"
                                BorderThickness="0" Padding="8,6"/>
                    </StackPanel>

                    <ListBox DockPanel.Dock="Top"
                             ItemsSource="{Binding Tabs}"
                             SelectedItem="{Binding SelectedTab}"
                             HorizontalContentAlignment="Stretch"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TerminalTabViewModel}">
                                <Grid Margin="4,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.RowSpan="2"
                                            Width="3" CornerRadius="2"
                                            Margin="0,0,8,0"
                                            Background="{Binding IsActive,
                                                Converter={StaticResource ActiveIndicatorBrush}}"/>

                                    <TextBlock Grid.Column="1" Grid.Row="0"
                                               Text="{Binding Title}"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="#CCCCCC"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                               Text="{Binding Cwd}"
                                               FontSize="11" Opacity="0.6"
                                               Foreground="#888"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding DataContext.ShowCwd,
                                                   RelativeSource={RelativeSource AncestorType=ListBox},
                                                   Converter={StaticResource BoolToVisibility}}"/>

                                    <Button Grid.Column="2" Grid.RowSpan="2"
                                            Content="✕" FontSize="10"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#888"
                                            Command="{Binding DataContext.CloseTabCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Width="22" Height="22" Padding="0"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="1"
                          Background="#3E3E42"
                          HorizontalAlignment="Center"/>

            <!-- Terminal area -->
            <Border Grid.Column="2" Background="Black">
                <controls:TerminalHostControl x:Name="TerminalHost"
                                              RenderResizeRequested="OnTerminalResized"/>
            </Border>
        </Grid>
    </Grid>

</Window>
