<ui:FluentWindow x:Class="GhostWin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:GhostWin.App.Controls"
        Title="GhostWin Terminal" Width="1024" Height="768"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TitleBar drag area -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent"/>

        <!-- Sidebar -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="8,4,8,8">
            <TextBlock Text="GhostWin" FontSize="16" FontWeight="Bold"
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,12"/>
            <TextBlock x:Name="StatusText" Text="Initializing..."
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Terminal rendering area (below titlebar) -->
        <Border Grid.Row="1" Grid.Column="1" Background="Black">
            <controls:TerminalHostControl x:Name="TerminalHost"
                                          RenderResizeRequested="OnTerminalResized"/>
        </Border>
    </Grid>
</ui:FluentWindow>
